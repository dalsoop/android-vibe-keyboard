<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="56dp"
    android:horizontalGap="0px"
    android:verticalGap="0px">

    <!-- Row 1: qwertyuiop -->
    <Row>
        <Key android:codes="113" android:keyLabel="q" android:keyWidth="10%p" />
        <Key android:codes="119" android:keyLabel="w" android:keyWidth="10%p" />
        <Key android:codes="101" android:keyLabel="e" android:keyWidth="10%p" />
        <Key android:codes="114" android:keyLabel="r" android:keyWidth="10%p" />
        <Key android:codes="116" android:keyLabel="t" android:keyWidth="10%p" />
        <Key android:codes="121" android:keyLabel="y" android:keyWidth="10%p" />
        <Key android:codes="117" android:keyLabel="u" android:keyWidth="10%p" />
        <Key android:codes="105" android:keyLabel="i" android:keyWidth="10%p" />
        <Key android:codes="111" android:keyLabel="o" android:keyWidth="10%p" />
        <Key android:codes="112" android:keyLabel="p" android:keyWidth="10%p" />
    </Row>

    <!-- Row 2: asdfghjkl -->
    <Row>
        <Key android:codes="97"  android:keyLabel="a" android:keyWidth="11%p" />
        <Key android:codes="115" android:keyLabel="s" android:keyWidth="11%p" />
        <Key android:codes="100" android:keyLabel="d" android:keyWidth="11%p" />
        <Key android:codes="102" android:keyLabel="f" android:keyWidth="11%p" />
        <Key android:codes="103" android:keyLabel="g" android:keyWidth="11%p" />
        <Key android:codes="104" android:keyLabel="h" android:keyWidth="11%p" />
        <Key android:codes="106" android:keyLabel="j" android:keyWidth="11%p" />
        <Key android:codes="107" android:keyLabel="k" android:keyWidth="11%p" />
        <Key android:codes="108" android:keyLabel="l" android:keyWidth="12%p" />
    </Row>

    <!-- Row 3: SHIFT zxcvbnm DELETE -->
    <Row>
        <Key android:codes="-1"  android:keyLabel="SHIFT" android:keyWidth="15%p" android:isModifier="true" />
        <Key android:codes="122" android:keyLabel="z" android:keyWidth="10%p" />
        <Key android:codes="120" android:keyLabel="x" android:keyWidth="10%p" />
        <Key android:codes="99"  android:keyLabel="c" android:keyWidth="10%p" />
        <Key android:codes="118" android:keyLabel="v" android:keyWidth="10%p" />
        <Key android:codes="98"  android:keyLabel="b" android:keyWidth="10%p" />
        <Key android:codes="110" android:keyLabel="n" android:keyWidth="10%p" />
        <Key android:codes="109" android:keyLabel="m" android:keyWidth="10%p" />
        <Key android:codes="-5"  android:keyLabel="DEL"  android:keyWidth="15%p" android:isRepeatable="true" />
    </Row>

    <!-- Row 4: MODE_CHANGE SPACE DONE -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-2" android:keyLabel="한글" android:keyWidth="20%p" />
        <Key android:codes="32" android:keyLabel=" "   android:keyWidth="60%p" android:isRepeatable="true" />
        <Key android:codes="-4" android:keyLabel="Done" android:keyWidth="20%p" />
    </Row>

</Keyboard>
